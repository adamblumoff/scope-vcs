{
  "name": "@scope/web",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check": "pnpm typecheck && pnpm check:api-contract && pnpm check:line-limit && pnpm check:react-doctor && pnpm check:konsistent",
    "check:api-contract": "node scripts/check-api-contract.mjs",
    "check:konsistent": "konsistent check",
    "check:line-limit": "node scripts/check-line-limit.mjs",
    "check:react-doctor": "react-doctor --blocking warning --no-score --yes",
    "konsistent": "konsistent check",
    "konsistent:validate": "konsistent validate",
    "start": "node .output/server/index.mjs",
    "test": "node -e \"const fs=require('node:fs'); fs.rmSync('.test-output',{recursive:true,force:true}); fs.mkdirSync('.test-output',{recursive:true}); fs.writeFileSync('.test-output/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\" && tsc -p tsconfig.test.json && node --test \".test-output/**/*.test.js\"",
    "test:smoke": "node --test \"smoke/**/*.spec.mjs\"",
    "typecheck": "tsc --noEmit",
    "ui:audit": "node scripts/ui-audit.mjs"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.4.5",
    "@pierre/diffs": "1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "github-slugger": "2.0.0",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "konsistent": "1.0.0-beta.1",
    "nitro": "^3.0.260311-beta",
    "playwright": "1.61.1",
    "react-doctor": "^0.5.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.14"
  }
}
