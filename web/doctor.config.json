  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": [".output/**", ".tanstack/**", ".test-output/**"],
    "overrides": [
      {
        "files": ["src/routes/repos.$owner.$repo.review.tsx"],
